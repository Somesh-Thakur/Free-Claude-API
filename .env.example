# Server port (default: 3000)
PORT=3000

# Optional: Your Puter API token for higher rate limits on the public API endpoint.
# Leave blank to use anonymous Puter access (subject to rate limiting).
# Get your token at: https://puter.com → Account → API Tokens
PUTER_API_KEY=

# Optional: Allowed CORS origins (comma-separated). Defaults to '*' (all origins).
# Example: CORS_ORIGINS=https://myapp.com,https://myapp2.com
CORS_ORIGINS=*
